<h1 class="mb-4">Mes Itinéraires</h1>

<div class="row row-cols-1 row-cols-md-3 g-4">
  <% @itineraries.each do |itinerary| %>
    <div class="col">
      <div class="card h-100 shadow-sm hover-shadow">

        <% if itinerary.events.any? %>
          <img src="<%= itinerary.events.first.image_url %>"
               class="card-img-top"
               alt="<%= itinerary.title %>">
        <% end %>

        <div class="card-body d-flex flex-column">

          <h5 class="card-title"><%= itinerary.title %></h5>

          <p class="card-text">
            <%= itinerary.events.map(&:title).join(", ") %>
          </p>

          <p class="text-muted mb-3">
            Budget max: €<%= itinerary.budget_max %> •
            Durée max: <%= itinerary.duration_max %> jours
          </p>

          <!-- Bouton en bas -->
          <div class="mt-auto">
            <%= link_to "Voir plus de détails",
                itinerary_path(itinerary),
                class: "btn btn-primary w-100 rounded-pill" %>
          </div>

        </div>
      </div>
    </div>
  <% end %>
</div>
