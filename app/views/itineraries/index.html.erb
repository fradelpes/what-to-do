<div class="itineraries-index container py-3 py-md-4">
  <h1 class="itineraries-index__title mb-4 text-center">Mes Parcours</h1>

  <% if @itineraries.any? %>
    <div class="row itineraries-grid g-2 g-md-4">
      <% @itineraries.each do |itinerary| %>
        <div class="col-12 col-md-6">
          <article class="event-card card h-100 shadow-sm border-0">
            <div class="event-card__media">
              <% cover_image = itinerary.events.first&.image_url %>
              <% if cover_image.present? %>
                <%= image_tag cover_image,
                    class: "event-card__image",
                    alt: itinerary.title %>
              <% else %>
                <%= image_tag "itineraries/mountains.jpg",
                    class: "event-card__image",
                    alt: itinerary.title %>
              <% end %>
            </div>

            <div class="card-body d-flex flex-column">
              <h5 class="card-title event-card__title mb-2"><%= itinerary.title %></h5>

              <% event_titles = itinerary.events.map(&:title).join(", ") %>
              <p class="card-text event-card__description text-muted mb-3">
                <%= event_titles.present? ? truncate(event_titles, length: 90) : "Aucun événement pour l’instant." %>
              </p>

              <div class="event-card__chips mb-3">
                <span class="event-chip">
                  <%= pluralize(itinerary.events.size, "activité") %>
                </span>
                <% if itinerary.duration_max.present? %>
                  <span class="event-chip">⏱ <%= itinerary.duration_max %>h max</span>
                <% end %>
                <% if itinerary.budget_max.present? %>
                  <span class="event-chip event-chip--highlight">💰 €<%= itinerary.budget_max %></span>
                <% end %>
              </div>

              <div class="mt-auto">
                <%= link_to "Voir plus",
                    itinerary_path(itinerary),
                    class: "btn itinerary-card__cta w-100" %>
              </div>
            </div>
          </article>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="itineraries-index__empty text-center mt-5">
      <p class="text-muted mb-3">Aucun parcours pour le moment.</p>
      <%= link_to "Voir mes chats", chats_path, class: "btn itinerary-card__cta px-4" %>
    </div>
  <% end %>
</div>
