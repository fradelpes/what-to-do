<div class="itinerary-show container py-3 py-md-4">
  <h1 class="itinerary-show__title mb-4 text-center"><%= @itinerary.title %></h1>

  <% if @itinerary.events.any? %>
    <div class="row itineraries-grid g-2 g-md-4">
      <% @itinerary.events.each do |event| %>
        <div class="col-12 col-md-6">
          <article class="event-card card h-100 shadow-sm border-0">
            <div class="event-card__media">
              <% if event.image_url.present? %>
                <%= image_tag event.image_url,
                    class: "event-card__image",
                    alt: event.title %>
              <% else %>
                <%= image_tag "itineraries/beach.jpg",
                    class: "event-card__image",
                    alt: event.title %>
              <% end %>
            </div>

            <div class="card-body d-flex flex-column">
              <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                <h5 class="card-title event-card__title mb-0"><%= event.title %></h5>
                <% if event.category.present? %>
                  <span class="badge bg-category event-card__badge"><%= event.category %></span>
                <% end %>
              </div>

              <p class="card-text event-card__description text-muted mb-3">
                <%= event.description.present? ? truncate(event.description, length: 110) : "Aucune description pour le moment." %>
              </p>

              <div class="event-card__chips mt-auto">
                <% if event.location.present? %>
                  <span class="event-chip">📍 <%= event.location %></span>
                <% end %>
                <% if event.duration.present? %>
                  <span class="event-chip">⏱ <%= event.duration %>h</span>
                <% end %>
                <% if event.price.present? %>
                  <span class="event-chip event-chip--highlight">💰 €<%= event.price %></span>
                <% end %>
              </div>
            </div>
          </article>
        </div>
      <% end %>
    </div>
  <% else %>
    <p class="text-muted">Aucun événement pour cet itinéraire.</p>
  <% end %>
</div>
