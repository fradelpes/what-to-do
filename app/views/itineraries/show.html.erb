<div class="container py-4">

    <%= link_to "Retour", itineraries_path, class: "btn btn-back px-4 py-2"  %>
  <h1 class="mb-4 text-center">
    <%= @itinerary.title %>
  </h1>

  <div class="row g-4">

    <% @itinerary.events.each do |event| %>

      <div class="col-12 col-md-6">

        <div class="card shadow-sm border-0 h-100">

         <% if event.image_url.present? %>
            <%= image_tag event.image_url,
            class: "card-img-top",
            alt: event.title,
            style: "height: 200px; object-fit: cover;" %>
         <% end %>


          <div class="card-body">

            <div class="d-flex justify-content-between align-items-start mb-2">
              <h5 class="card-title mb-0"><%= event.title %></h5>
              <span class="badge bg-category">
                <%= event.category %>
              </span>
            </div>

            <p class="card-text text-muted small">
              <%= truncate(event.description, length: 80) %>
            </p>

            <div class="mt-3 small">
              <p class="mb-1">📍 <%= event.location %></p>
              <p class="mb-1">⏱ <%= event.duration %>h</p>
              <p class="fw-bold mb-0">
                💰 €<%= event.price %>
              </p>
            </div>

          </div>

        </div>

      </div>


    <% end %>

  </div>

</div>
