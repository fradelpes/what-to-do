<div class="container mt-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Mes chats</h2>

    <%= button_to " + Nouveau Chat",
        chats_path,
        method: :post,
        class: "btn btn-chat" %>
  </div>

  <% if @chats.any? %>
    <ul class="list-group">
      <% @chats.each do |chat| %>
        <li class="list-group-item d-flex justify-content-between align-items-center">
          <div>
            <strong>Chat #<%= chat.id %></strong>
            <br>
            <small class="text-muted">
              Créé le <%= chat.created_at.strftime("%d/%m/%Y à %H:%M") %>
            </small>
          </div>

          <div>
            <%= link_to "Ouvrir",
                chat_path(chat),
                class: "btn btn-sm btn-outline-primary" %>
          </div>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-3">Tu n’as encore aucune conversation.</p>
  <% end %>

</div>
