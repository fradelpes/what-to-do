<div class="container py-4">

  <h1 class="mb-4">Mes Itinéraires</h1>

  <div class="row g-4">

    <% @itineraries.each do |itinerary| %>
      <div class="col-12 col-md-6 col-lg-4">

        <div class="card h-100 shadow-sm">

          <% if itinerary.events.any? && itinerary.events.first.image_url.present? %>
            <img src="<%= itinerary.events.first.image_url %>"
                 class="card-img-top"
                 alt="<%= itinerary.title %>">
          <% end %>

          <div class="card-body d-flex flex-column">

            <h5 class="card-title"><%= itinerary.title %></h5>

            <p class="text-muted small">
              <%= pluralize(itinerary.events.count, "activité") %>
            </p>

            <p class="text-muted">
              Budget max : €<%= itinerary.budget_max %> •
              Durée max : <%= itinerary.duration_max %> jours
            </p>

            <div class="mt-auto">
              <%= link_to "Voir l’itinéraire",
                  itinerary_path(itinerary),
                  class: "btn btn-primary w-100 rounded-pill" %>
            </div>

          </div>
        </div>

      </div>
    <% end %>

  </div>
</div>
