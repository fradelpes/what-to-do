<div class="container mt-4">
  <h2>Chat #<%= @chat.id %></h2>
  <div class="chat-messages mb-4">
    <% @chat.messages.order(:created_at).each do |message| %>
      <div class="message message-<%= message.role %>">
        <strong><%= message.role == "user" ? "Vous" : "Assistant" %></strong>

        <% if message.content.include?("ID_ITINERARY:") %>
          <% itinerary_id = message.content.match(/ID_ITINERARY:(\d+)/)&.captures&.first %>
          <p>Votre itinéraire a été créé avec succès !</p>
          <%= link_to "Voir les détails et les événements", "/itineraries/#{itinerary_id}", class: "btn btn-primary mt-2" %>
        <% else %>
          <p><%= message.content %></p>
        <% end %>
      </div>
    <% end %>
  </div>

  <%= form_with model: [@chat, Message.new], class: "chat-form" do |f| %>
    <div class="input-group">
      <%= f.text_field :content, placeholder: "Décris ce que tu cherches...", class: "form-control", autofocus: true %>
      <%= f.submit "Envoyer", class: "btn btn-chat" %>
    </div>
  <% end %>
  <div class="mb-3">
  <%= link_to "Retour", itineraries_path, class: "btn btn-chat mt-3" %>
  </div>
</div>
